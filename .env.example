# Aegis Threat Intel Environment Configuration
# Copy to .env and fill in your values

# Anthropic API key (for Cloud AI mode)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Abuse.ch Auth Key (for URLhaus + ThreatFox feeds)
# Register free at https://auth.abuse.ch/
ABUSE_CH_AUTH_KEY=

# Feed poll interval in milliseconds (default: 1 hour)
# POLL_INTERVAL_MS=3600000

# Database path (default: ./aegis-intel.db)
# DB_PATH=./aegis-intel.db

# Server port (default: 4001)
# PORT=4001

# Vite dev server port (default: 5174). Override per host if you need a
# different port.
# CLIENT_PORT=5174

# ── CVE MCP Threat-Intel Enrichment (optional) ──────────────────────────────
# Connects Aegis's AI analyst to the audited cve-mcp Python server for
# IOC enrichment via NVD, EPSS, KEV, AbuseIPDB, GreyNoise, Shodan, VirusTotal,
# URLScan, MITRE ATT&CK, and crt.sh.
#
# Prerequisite: cve-mcp installed at ~/Dev/cve-mcp-server with .env populated.
# See: https://github.com/mukul975/cve-mcp-server

# Enable cve-mcp integration (default: true; set false to disable enrichment tools)
# CVE_MCP_ENABLED=true

# Path to the cve-mcp Python interpreter (default: $HOME/Dev/cve-mcp-server/.venv/bin/python)
# CVE_MCP_PYTHON=

# Path to the cve-mcp install directory (default: $HOME/Dev/cve-mcp-server)
# CVE_MCP_CWD=
